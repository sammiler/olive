{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/.vscode/ps-script/configure.ps1",
                "-BuildType",
                "${input:buildType}",
                "-CMakeFlags",
                "${input:cmakeFlags}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Cmake configure  build project"
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/.vscode/ps-script/build.ps1",
                "-BuildType",
                "${input:buildType}"
            ],
            "options": {
                
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "cmake-configure",
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build the project by cmake"
        },{
            "label": "cmake-install",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/.vscode/ps-script/install.ps1",
                "-BuildType",
                "${input:buildType}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "group": "build",
            "detail": "Use cmake to install the project"
        },
        {
            "label": "cmake-clean",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/.vscode/ps-script/clean.ps1",
                "-BuildType",
                "${input:buildType}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Use cmake to clean the project"
        },
        {
            "label": "generate-launch",
            "type": "shell",
            "command": "node",
            "args": [
                "${workspaceFolder}/.vscode/node-script/generate_launch.js"
            ],
            "group": {
                "kind": "build"
            },
            "dependsOn": "cmake-build",
            "problemMatcher": [],
            "detail": "Generate launch.json for users to debug,especially for tests exe."
        },
        {
            "label": "Generate Qt Resources",
            "type": "shell",
            "command": "node",
            "args": [
                "${workspaceFolder}/.vscode/node-script/qrc-snippets.js"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Generate Qt's resource compiler"
        },
        {
            "label": "Copy DLLs",
            "type": "shell",
            "command": "node ${workspaceFolder}/.vscode/node-script/copy-dll.js",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
    ],
    "inputs": [
        {
            "id": "buildType",
            "type": "pickString",
            "description": "Select build type",
            "options": ["Debug", "Release"],
            "default": "Debug"
        },
        {
            "id": "cmakeFlags",
            "type": "pickString",
            "description": "Select compiler flags",
            "options": [
                "-DCMAKE_CXX_FLAGS=/EHsc /W3 /MP6 /Zi /FS /MDd /D_ITERATOR_DEBUG_LEVEL=2 -DCMAKE_C_FLAGS=/EHsc /W3 /MP6 /Zi /FS /MDd /D_ITERATOR_DEBUG_LEVEL=2",
                "-DCMAKE_CXX_FLAGS=/EHsc /W3 /MP6 /O2 /FS /MD -DCMAKE_C_FLAGS=/EHsc /W3 /MP6 /O2 /FS /MD"
            ],
            "default": "-DCMAKE_CXX_FLAGS=/EHsc /W3 /MP6 /Zi /FS /MDd /D_ITERATOR_DEBUG_LEVEL=2 -DCMAKE_C_FLAGS=/EHsc /W3 /MP6 /Zi /FS /MDd /D_ITERATOR_DEBUG_LEVEL=2"
        }
    ]
}