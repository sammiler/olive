{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "cmake-configure",
                "--build-type",
                "${input:buildType}",
                "--cmake-flags",
                "${input:cmakeFlags}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Cmake configure  build project"
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "cmake-build",
                "--build-type",
                "${input:buildType}"
            ],
            "options": {
                
                "cwd": "${workspaceFolder}",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "cmake-configure",
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build the project by cmake"
        },{
            "label": "cmake-install",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "cmake-install",
                "--build-type",
                "${input:buildType}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "group": "build",
            "detail": "Use cmake to install the project"
        },
        {
            "label": "cmake-clean",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "cmake-clean",
                "--build-type",
                "${input:buildType}"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Use cmake to clean the project"
        },
        {
            "label": "Generate Conan Files",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "generate_conan"
            ],
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false
            }
        },
        {
            "label": "Generate Qt Resources",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "generate-qrc"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Generate Qt's resource compiler"
        },

        {
            "label": "Copy DLLs",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "copy-dll"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Launch Terminal (Full Env)",
            "type": "shell",
            "command": "python",
            "args": [
                ".vscode/py-script/main.py",
                "--task",
                "launch-terminal",
                "--param",
                "full"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "buildType",
            "type": "pickString",
            "description": "Select build type",
            "options": ["Debug", "Release"],
            "default": "Debug"
        },
        {
            "id": "cmakeFlags",
            "type": "pickString",
            "description": "Select compiler flags",
            "options": [
                "${debug_flag}",
                "${rel_flag}"
            ],
            "default": "${debug_flag}"
        }
    ]
}